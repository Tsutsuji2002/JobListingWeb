# ============================================================
# JobListingWeb - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
# ============================================================

# -------------------- Database --------------------
DB_SA_PASSWORD=YourStrong@Passw0rd123
DB_NAME=JobListingWebDatabase

# -------------------- Redis --------------------
REDIS_PASSWORD=YourRedisPassword123

# -------------------- Application --------------------
ASPNETCORE_ENVIRONMENT=Development

# -------------------- JWT Authentication --------------------
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-key-at-least-32-chars-long
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=ApplicationUser

# -------------------- Google OAuth (Optional) --------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -------------------- Email Settings (Optional) --------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=JobListingWeb

# -------------------- Azure Blob Storage --------------------
# For local development, use Azurite or set UseDevelopmentStorage=true
# For production, use your Azure Blob Storage connection string
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# -------------------- AI / Gemini (Optional) --------------------
GEMINI_API_KEY=your-gemini-api-key

# -------------------- OpenAI (Optional) --------------------
OPENAI_API_KEY=your-openai-api-key

# -------------------- Frontend URL --------------------
REACT_APP_API_URL=https://localhost:7082/api
REACT_APP_UI_URL=https://localhost:3000
